# SHL Assessment Recommender — Environment Variables Template
# Copy this file to .env and fill in your actual values.

# Google AI Studio API Key (from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Model identifier (e.g., gemini-1.5-flash or gemini-2.0-flash)
MODEL_NAME=gemini-3.1-flash-lite

# Port for the FastAPI server
PORT=8000

# Path to the catalog JSON file (relative to root)
CATALOG_PATH=data/shl_catalog.json
